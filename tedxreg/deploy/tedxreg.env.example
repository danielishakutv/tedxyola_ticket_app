# Copy to /etc/tedxreg.env on the server, fill in strong values, then:
#   sudo chmod 600 /etc/tedxreg.env
#   sudo chown root:root /etc/tedxreg.env
# This file holds secrets — it is NOT committed (only this .example is).

PORT=8787
DATA_DIR=/var/lib/tedxreg

# Login credentials for the live app (use strong, unique values):
ADMIN_PASSWORD=replace-with-strong-admin-password
USER_PASSWORD=replace-with-staff-password

# Optional — override the default usernames (default: admin / user)
# ADMIN_USERNAME=admin
# USER_USERNAME=user
